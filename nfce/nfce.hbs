<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <style>
    {{{css}}}
    </style>
</head>
<body id="nfce-body">

    <div class="text-center emitente-header">
        <span class="emitente-nome bold">{{emitente.nome}}</span><br>
        CNPJ:{{emitente.inscricao_nacional}} IE:{{emitente.ie}}<br>
        {{emitente.logradouro}},{{emitente.numero}},{{emitente.bairro}}. CEP:{{emitente.cep}}.<br>
        {{emitente.municipio}}-{{emitente.uf}} - {{emitente.telefone}}
    </div>

    <div class="dashed-line"></div>

    <div class="text-center bold" style="font-size: 9pt;">DANFE NFC-e</div>
    <div class="text-center" style="font-size: 7pt;">Documento Auxiliar da Nota Fiscal de Consumidor Eletrônica</div>
    <div class="text-center" style="font-size: 6pt;">NFC-e não permite aproveitamento de crédito de ICMS</div>

    <div class="dashed-line"></div>

    <table>
        <thead>
            <tr>
                <th>CÓD</th>
                <th>DESCRIÇÃO</th>
                <th>QTD</th>
                <th>UN</th>
                <th>VL UN</th>
                <th>VL TOTAL</th>
            </tr>
        </thead>
        <tbody>
            {{#each itens}}
            <tr>
                <td>{{codigo}}</td>
                <td>{{descricao}}</td>
                <td>{{qtd}}</td>
                <td>{{un}}</td>
                <td>{{valor_unit}}</td>
                <td>{{valor_total}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="dashed-line"></div>

    <div class="total-container">
        <div class="total-row">
            <span>Qtd. Total de Itens</span>
            <span>{{qtd_total_itens}}</span>
        </div>
        <div class="total-row">
            <span>Valor Total dos Produtos</span>
            <span>R$ {{valor_total_produtos}}</span>
        </div>
        <div class="total-row">
            <span>Total do Desconto</span>
            <span>R$ {{total_desconto}}</span>
        </div>
        <div class="total-row">
            <span>Total do Frete</span>
            <span>R$ {{total_frete}}</span>
        </div>
        <div class="total-row bold">
            <span>VALOR TOTAL DA NOTA</span>
            <span>R$ {{valor_total_nota}}</span>
        </div>
    </div>

    <div class="dashed-line"></div>

    <div class="total-container">
        <div class="total-row">
            <span>Informação dos Tributos Totais Incidentes</span>
            <span>R$ {{valor_total_tributos}}</span>
        </div>
    </div>

    <div class="dashed-line"></div>

    <div class="pagamento-header">
        <span>FORMA DE PAGAMENTO</span>
        <span>VALOR PAGO</span>
    </div>
    {{#each pagamentos}}
    <div class="total-row">
        <span>{{forma}}</span>
        <span>R$ {{valor}}</span>
    </div>
    {{/each}}

    <div class="dashed-line"></div>

    <div class="text-center mensagem-fiscal">
        ÁREA DE MENSAGEM FISCAL<br>
        Número {{numero}} Série {{serie}} {{data_emissao}} - Via Consumidor
    </div>

    <div class="dashed-line"></div>

        <div class="text-center">
        CONSUMIDOR<br>
        <span class="bold">{{destinatario.nome}}</span>
        {{#if destinatario.identificacao}}<br>{{destinatario.identificacao}}{{/if}}
    </div>


        <div class="dashed-line"></div>

    <div class="info-adicional">
        <span class="bold">INFORMAÇÃO ADICIONAL</span><br>
        {{informacoes_complementares}}
    </div>

    <div class="dashed-line"></div>
<div class="text-center info-fiscal">
        Consulte pela Chave de Acesso em<br>
        {{#if url_consulta_qrcode}}
        <span style="font-size: 6pt;">{{url_consulta_qrcode}}</span><br>
        {{/if}}
        <div class="chave-label">CHAVE DE ACESSO</div>
        <div class="chave-acesso">{{chave}}</div>
    </div>
<div class="text-center info-fiscal">
        Protocolo de Autorização: {{protocolo}}<br>
        {{data_protocolo}}
    </div>




    <div class="dashed-line"></div>
    <div id="qrcode-placeholder"></div>
</body>
</html>
