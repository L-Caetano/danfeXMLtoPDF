<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <style>
    {{{css}}}
  </style>
</head>

<body>
<div class="container">

<table style="width:100%; border-collapse:collapse;">

  <tr>

    <td style="width:38%; padding:0; vertical-align:top;">

    <table style="width:100%; border-collapse:collapse;">
  <tr class="h97">
    <td style="vertical-align: middle; text-align: center;">

      {{#if logo}}
        <div style="margin-bottom: 5px;">
          <img
            src="{{logo}}"
            style="max-height:55px; max-width:120px;"
          />
        </div>
      {{/if}}

      <div class="value center bold" style="font-size: 12pt; margin-bottom: 4px; line-height: 1.2;">
        {{emitente.nome}}
      </div>

      <div style="font-size: 7pt; line-height: 1.1;">
        <div class="value center">
          {{emitente.endereco.linha1}}
        </div>

        <div class="value center">
          {{emitente.endereco.linha2}}
        </div>

        <div class="value center">
          CEP {{emitente.endereco.cep}}
        </div>

        <div class="value center">
          {{emitente.fone}}
        </div>

        <div class="value center">
          CNPJ: {{emitente.documento}}
        </div>

        <div class="value center">
          IE: {{emitente.ie}}
        </div>
      </div>

    </td>
  </tr>
</table>

<table style="width:100%; border-collapse:collapse;">
        <tr>

          <td style="width:50%;" class="h30">

            <span class="label center">
              TIPO DO CT-E
            </span>

            <span class="value  center">
              {{tipo_cte}}
            </span>

          </td>

          <td style="width:50%;" class="h30">

            <span class="label center">
              TIPO DO SERVIÇO
            </span>

            <span class="value  center">
              {{servico}}
            </span>

          </td>

        </tr>

        <tr>

          <td class="h30">

            <span class="label center">
              TOMADOR DO SERVIÇO
            </span>

            <span class="value  center">
              {{tomador.nome}}
            </span>

          </td>

          <td class="h30">

            <span class="label center">
              FORMA DE PAGAMENTO
            </span>

            <span class="value bold center">
              {{formaPagamento}}
            </span>

          </td>

        </tr>

      </table>

    </td>

    <td style="width:62%; padding:0; vertical-align:top;">

      <table style="width:100%; border-collapse:collapse;">

        <tr>

          <td
            style="width:60%;"
            class="center h40"
          >

            <div class="bold" style="font-size: large">
              DACTE
            </div>

            <div class="tiny">
              DOCUMENTO AUXILIAR DO
              CONHECIMENTO DE TRANSPORTE
              ELETRÔNICO
            </div>

          </td>

          <td class="h40">

            <span class="label center">
              MODAL
            </span>

            <span class="value center bold">
              {{modal}}
            </span>

          </td>

        </tr>

      </table>

      <table style="width:100%; border-collapse:collapse;">

        <tr>

          <td class="h30" colspan="2">

            <span class="label center">
              MODELO
            </span>

            <span class="value center bold">
              57
            </span>

          </td>

          <td class="h30" colspan="2">

            <span class="label center">
              SÉRIE
            </span>

            <span class="value center bold">
              {{serie}}
            </span>

          </td>

          <td class="h30" colspan="3">

            <span class="label center">
              NÚMERO
            </span>

            <span class="value center bold">
              {{numero}}
            </span>

          </td>

          <td class="h30">

            <span class="label center">
              FL
            </span>

            <span class="value center bold">
              1/1
            </span>

          </td>

          <td class="h30" colspan="4">

            <span class="label center">
              DATA E HORA DE EMISSÃO
            </span>

            <span class="value center bold">
              {{data_emissao}}
            </span>

          </td>

          <td colspan="4" class="h30">

            <span class="label center" >
              INSC. SUFRAMA DO DESTINATÁRIO
            </span>

            <span class="value center bold">
              {{destinatario.suframa}}
            </span>

          </td>

        </tr>

      </table>

      <table style="width:100%; border-collapse:collapse;">

        <tr>

          <td colspan="5" class="center h40">
            <svg id="barcode"></svg>
          </td>

        </tr>

        <tr>

          <td colspan="5" class="center h30">

            <span class="label">
              CHAVE DE ACESSO
